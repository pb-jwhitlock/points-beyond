---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
  { href: '/faq', label: 'FAQ' },
];
const currentPath = Astro.url.pathname;
---

<header>
  <nav class="container">
    <a href="/" class="logo">
      <img src="/logo.png" alt="Points Beyond Logo" width="30" height="30" />
      <span class="logo-text">Points Beyond</span>
    </a>

    <ul class="nav-links">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class:list={['nav-link', { active: currentPath === link.href }]}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="ai-status">
      <span class="status-dot"></span>
      <span class="status-text">AI DISPATCH: ACTIVE</span>
    </div>
  </nav>
</header>

<style>
  header {
    width: 100%;
    background: transparent !important; /* Removes the white background */
    border-bottom: none !important;     /* Removes the separation line */
    position: absolute;                /* Floats the header over the hero */
    top: 0;
    left: 0;
    z-index: 100;
    padding: 1.5rem 2rem;
  }
  nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: #1a202c;
    font-weight: 700;
    font-size: 1.2rem;
    white-space: nowrap;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-link {
    color: #4a5568;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .nav-link:hover, .nav-link.active {
    color: #1a202c;
  }
  .ai-status {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: #f0fff4;
    border: 1px solid #c6f6d5;
    border-radius: 6px;
    color: #2f855a;
    font-size: 0.65rem;
    font-weight: 700;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .status-dot {
    width: 6px;
    height: 6px;
    background-color: #38a169;
    border-radius: 50%;
    box-shadow: 0 0 5px #38a169;
    animation: pulse 2s infinite;
    flex-shrink: 0;
  }
  @keyframes pulse {
    0% { opacity: 0.5; }
    50% { opacity: 1; }
    100% { opacity: 0.5; }
  }

  @media (max-width: 768px) {
    header {
      padding: 0.75rem 1rem;
      overflow-x: hidden;
    }
    /* Row 1: logo (left) + ai-status (right)
       Row 2: nav-links (full width) */
    nav {
      flex-wrap: wrap;
      gap: 0.4rem 0;
      padding: 0;
      align-items: center;
    }
    .logo {
      flex: 1;
    }
    .ai-status {
      order: 2;
      font-size: 0.55rem;
      padding: 3px 7px;
      gap: 4px;
    }
    .status-dot {
      width: 5px;
      height: 5px;
    }
    .nav-links {
      order: 3;
      flex: 0 0 100%;
      flex-wrap: wrap;
      gap: 0.1rem 0.65rem;
    }
    .nav-link {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .nav-link {
      font-size: 0.8rem;
    }
    .nav-links {
      gap: 0.1rem 0.5rem;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.mobile-toggle');
  const navLinks = document.querySelector('.nav-links');
  toggle?.addEventListener('click', () => {
    navLinks?.classList.toggle('open');
  });
</script>