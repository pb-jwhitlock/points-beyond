---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    q: "What is Answer Engine Optimization (AEO)?",
    a: "Answer Engine Optimization (AEO) is the practice of structuring your content so that AI systems like ChatGPT, Perplexity, Google AI Overview, and Claude cite your business as the authoritative answer when users ask questions in your industry. Unlike traditional SEO which focuses on link clicks, AEO focuses on becoming the definitive source AI trusts enough to quote directly."
  },
  {
    q: "How does Points Beyond help businesses appear in AI search results?",
    a: "Points Beyond analyzes the questions your customers ask AI systems, then restructures and creates content that directly answers those questions with authority. We optimize your website architecture, content format, and credibility signals so AI engines consistently cite your business in their responses."
  },
  {
    q: "What is the difference between AEO and SEO?",
    a: "Traditional SEO optimizes content for Google's ranking algorithm to appear in blue link results. AEO optimizes content to be cited by AI answer engines like ChatGPT and Perplexity. Both are essential today — Points Beyond combines proven SEO fundamentals with AEO strategies to ensure visibility across all search surfaces."
  },
  {
    q: "How much does the AI Voice Receptionist service cost?",
    a: "The Points Beyond AI Voice Receptionist service is available for $599. It provides 24/7 AI-powered call handling that books appointments, answers frequently asked questions, and delivers call summaries to your inbox — ensuring you never miss a customer inquiry."
  },
  {
    q: "Who is Points Beyond best suited for?",
    a: "Points Beyond works with small to mid-size businesses and federal organizations in the Washington D.C. metropolitan area and nationally. We specialize in businesses that need to increase their visibility in AI-generated search results, particularly in competitive local and professional services markets."
  },
  {
    q: "What industries does Points Beyond serve?",
    a: "Points Beyond serves professional services, federal agencies and contractors, healthcare, legal, financial services, and local businesses. Founder John Whitlock brings over a decade of enterprise transformation experience from the defense, security, and justice sectors."
  },
  {
    q: "How long does it take to see results from AEO?",
    a: "AEO results typically begin appearing within 4–8 weeks as AI systems re-crawl and re-index your content. SEO results generally take 3–6 months. Points Beyond provides a clear roadmap with measurable milestones so you can track progress from day one."
  },
  {
    q: "Where is Points Beyond located?",
    a: "Points Beyond is based in Fairfax County, Virginia, and primarily serves clients in the Washington D.C. metropolitan area including Northern Virginia, Maryland, and D.C. proper. We also serve clients nationally."
  },
  {
    q: "Does Points Beyond offer SEO alongside AEO?",
    a: "Yes. Points Beyond offers comprehensive Search Engine Optimization (SEO) combined with Answer Engine Optimization. This includes Google Business Profile optimization, local search ranking, technical SEO, and content strategy — ensuring you rank in both traditional results and AI-curated responses."
  },
  {
    q: "How do I get started with Points Beyond?",
    a: "Contact Points Beyond through the website at pointsbeyond.ai/contact or connect with founder John Whitlock on LinkedIn. We begin with a free consultation to assess your current search visibility and identify the highest-impact opportunities for AI and search optimization."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};
---

<Layout
  title="FAQ | Answer Engine Optimization & AI Content Strategy | Points Beyond"
  description="Frequently asked questions about Answer Engine Optimization (AEO), SEO, and AI content strategy from Points Beyond. Learn how to get your business cited in ChatGPT, Google AI, and Perplexity."
  canonical="https://pointsbeyond.ai/faq/"
  schema={faqSchema}
>
  <section class="page-header">
    <div class="container">
      <h1>Frequently Asked Questions</h1>
      <p>Everything you need to know about AEO, SEO, and AI content strategy</p>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      {faqs.map((faq, i) => (
        <div class="faq-item">
          <h2>{faq.q}</h2>
          <p>{faq.a}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-card">
        <h2>Still have questions?</h2>
        <p>Let's talk through your specific situation.</p>
        <a href="/contact/" class="cta">Contact Us</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 3rem 2rem 1.5rem;
    text-align: center;
    position: relative;
  }

  .page-header h1 {
    font-size: 3rem;
    margin-bottom: 0.75rem;
    color: #2e1f7a;
  }

  .page-header p {
    color: var(--color-text-muted);
    font-size: 1.2rem;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .faq {
    padding: 1rem 2rem 2rem;
  }

  .faq-item {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-item h2 {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .faq-item p {
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 1rem;
  }

  .cta-section {
    padding: 0 2rem 2rem;
  }

  .cta-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 24px;
    padding: 2rem;
    text-align: center;
  }

  .cta-card h2 {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .cta-card p {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .cta {
    display: inline-block;
    background: linear-gradient(135deg, #4335b8 0%, #2e1f7a 100%);
    color: white;
    padding: 1rem 2.5rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
  }

  .cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(46, 31, 122, 0.4);
    color: white;
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .page-header h1 { font-size: 2rem; }
    .faq-item h2 { font-size: 1rem; }
  }
</style>
